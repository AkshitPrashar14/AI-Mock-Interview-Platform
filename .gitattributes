# =============================================================================
# AI Mock Interview Platform — .gitattributes
#
# Purpose:
#   Enforce consistent line endings across all platforms (Windows / macOS / Linux).
#   Prevent CRLF/LF conflicts in diffs and file comparisons.
#
# Strategy:
#   - All text files: auto-detect + normalize to LF in the repository.
#   - Language-specific overrides for guaranteed LF or CRLF.
#   - Binary files: marked binary so Git never attempts EOL conversion.
# =============================================================================

# ---- Default: auto-normalize all text files to LF ----
* text=auto eol=lf

# ---- Java ----
*.java        text eol=lf
*.kt          text eol=lf
*.kts         text eol=lf
*.groovy      text eol=lf
*.gradle      text eol=lf
*.xml         text eol=lf
*.properties  text eol=lf

# ---- Build ----
pom.xml       text eol=lf
*.mvn         text eol=lf

# ---- Configuration / YAML ----
*.yml         text eol=lf
*.yaml        text eol=lf
*.toml        text eol=lf
*.ini         text eol=lf
*.cfg         text eol=lf

# ---- Web / TypeScript / JavaScript ----
*.ts          text eol=lf
*.tsx         text eol=lf
*.js          text eol=lf
*.jsx         text eol=lf
*.mjs         text eol=lf
*.cjs         text eol=lf
*.json        text eol=lf
*.css         text eol=lf
*.scss        text eol=lf
*.html        text eol=lf
*.htm         text eol=lf

# ---- Python (stt-service) ----
*.py          text eol=lf
*.pyi         text eol=lf
*.pyx         text eol=lf
*.pxd         text eol=lf
requirements*.txt text eol=lf
Pipfile       text eol=lf
pyproject.toml text eol=lf

# ---- Documentation ----
*.md          text eol=lf
*.mdx         text eol=lf
*.txt         text eol=lf
*.rst         text eol=lf
*.adoc        text eol=lf

# ---- SQL / Database ----
*.sql         text eol=lf

# ---- Shell / Scripts ----
*.sh          text eol=lf
*.bash        text eol=lf
*.zsh         text eol=lf
*.fish        text eol=lf
Makefile      text eol=lf
Dockerfile    text eol=lf
*.dockerfile  text eol=lf
.dockerignore text eol=lf

# ---- Windows-only scripts (CRLF required) ----
*.bat         text eol=crlf
*.cmd         text eol=crlf
*.ps1         text eol=crlf

# ---- Git ----
.gitignore      text eol=lf
.gitattributes  text eol=lf

# ---- Binary: Images ----
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.svg    binary
*.webp   binary
*.bmp    binary
*.tiff   binary

# ---- Binary: Documents ----
*.pdf    binary
*.docx   binary
*.xlsx   binary
*.pptx   binary

# ---- Binary: Archives / Compiled ----
*.jar    binary
*.war    binary
*.ear    binary
*.zip    binary
*.tar    binary
*.gz     binary
*.tgz    binary
*.7z     binary

# ---- Binary: Fonts ----
*.ttf    binary
*.woff   binary
*.woff2  binary
*.eot    binary
*.otf    binary
